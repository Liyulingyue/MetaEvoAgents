# Workspace configuration
# 绝对路径或相对于项目根目录的路径
WORKSPACE_ROOT=./workspace

# Active template name (builtin) or absolute path (external)
# 内置模板名 (如 default) 或 外部模板的绝对路径
ACTIVE_TEMPLATE=default

# LLM Configuration
# OpenAI API Key (必填)
OPENAI_API_KEY=your_key_here

# OpenAI API Base URL (可选, 默认为 https://api.openai.com/v1)
OPENAI_URL=https://api.openai.com/v1

# OpenAI Model Name (可选, 默认为 gpt-4o-mini)
OPENAI_MODEL_NAME=gpt-4o-mini

